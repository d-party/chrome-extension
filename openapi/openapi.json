{
  "openapi": "3.0.3",
  "info": {
    "title": "d-party backend API",
    "version": "1.0.0",
    "description": "Public REST surface of the d-party backend consumed by the Chrome extension. The full schema can later be generated by drf-spectacular (`manage.py spectacular`)."
  },
  "servers": [{ "url": "/" }],
  "paths": {
    "/api/v1/chrome-extension/version-check": {
      "get": {
        "operationId": "versionCheck",
        "summary": "Check whether an extension version is compatible with the backend.",
        "parameters": [
          {
            "name": "extension-version",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Extension version in strict x.y.z form."
          }
        ],
        "responses": {
          "200": {
            "description": "Compatibility result.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/VersionCheckResult" }
              }
            }
          },
          "400": {
            "description": "Missing extension-version parameter.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiMessage" }
              }
            }
          },
          "406": {
            "description": "Malformed version string.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiMessage" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "VersionCheckResult": {
        "type": "object",
        "required": ["is_possible"],
        "properties": {
          "is_possible": {
            "type": "boolean",
            "description": "True if the extension version is supported."
          }
        }
      },
      "ApiMessage": {
        "type": "object",
        "required": ["message"],
        "properties": {
          "message": { "type": "string" }
        }
      }
    }
  }
}
